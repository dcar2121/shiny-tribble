<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dwayne Hans Jr - Elite Cybersecurity Architect</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cyber-cyan: #00ffff;
            --cyber-magenta: #ff00ff;
            --cyber-yellow: #ffff00;
            --neon-green: #39ff14;
            --electric-blue: #0080ff;
            --deep-black: #000000;
            --dark-gray: #0a0a0a;
            --mid-gray: #1a1a1a;
            --light-gray: #2a2a2a;
            --text-white: #ffffff;
            --text-gray: #cccccc;
        }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--deep-black);
            color: var(--text-white);
            overflow-x: hidden;
            line-height: 1.6;
            position: relative;
        }

        /* Animated Grid Background */
        .cyber-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background-image: 
                linear-gradient(rgba(0, 255, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 255, 255, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            animation: gridScroll 20s linear infinite;
        }

        @keyframes gridScroll {
            0% { background-position: 0 0; }
            100% { background-position: 50px 50px; }
        }

        /* Scanline Effect */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
            background: repeating-linear-gradient(
                0deg,
                rgba(0, 255, 255, 0.03) 0px,
                transparent 2px,
                transparent 4px
            );
            animation: scanlineMove 8s linear infinite;
        }

        @keyframes scanlineMove {
            0% { transform: translateY(0); }
            100% { transform: translateY(100px); }
        }

        /* Floating Particles */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: var(--cyber-cyan);
            opacity: 0.5;
            animation: particleFloat 15s linear infinite;
        }

        @keyframes particleFloat {
            0% {
                transform: translateY(100vh) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.5;
            }
            90% {
                opacity: 0.5;
            }
            100% {
                transform: translateY(-100px) translateX(100px);
                opacity: 0;
            }
        }

        /* Main Container */
        .resume-wrapper {
            position: relative;
            z-index: 2;
            max-width: 1600px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Terminal Header */
        .terminal-header {
            background: var(--dark-gray);
            border: 2px solid var(--cyber-cyan);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
            box-shadow: 0 0 20px rgba(0, 255, 255, 0.3), inset 0 0 20px rgba(0, 255, 255, 0.05);
            animation: fadeInDown 1s ease-out;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .terminal-line {
            font-family: 'Share Tech Mono', monospace;
            color: var(--neon-green);
            font-size: 14px;
            margin-bottom: 5px;
        }

        .cursor {
            display: inline-block;
            width: 10px;
            height: 18px;
            background: var(--cyber-cyan);
            animation: blink 1s infinite;
            margin-left: 5px;
        }

        @keyframes blink {
            0%, 49% { opacity: 1; }
            50%, 100% { opacity: 0; }
        }

        /* Hero Section */
        .hero {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 40px;
            margin-bottom: 40px;
            animation: fadeIn 1.5s ease-out 0.3s both;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .avatar-container {
            position: relative;
        }

        .avatar-frame {
            position: relative;
            width: 300px;
            height: 300px;
            background: var(--mid-gray);
            border: 3px solid var(--cyber-cyan);
            box-shadow: 
                0 0 30px rgba(0, 255, 255, 0.5),
                inset 0 0 30px rgba(0, 255, 255, 0.1);
            clip-path: polygon(0 0, 100% 0, 100% 85%, 85% 100%, 0 100%);
            overflow: hidden;
            animation: glowPulse 3s ease-in-out infinite;
        }

        @keyframes glowPulse {
            0%, 100% {
                box-shadow: 0 0 30px rgba(0, 255, 255, 0.5), inset 0 0 30px rgba(0, 255, 255, 0.1);
                border-color: var(--cyber-cyan);
            }
            50% {
                box-shadow: 0 0 50px rgba(255, 0, 255, 0.6), inset 0 0 40px rgba(255, 0, 255, 0.2);
                border-color: var(--cyber-magenta);
            }
        }

        .avatar-photo {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .avatar-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', sans-serif;
            font-size: 80px;
            font-weight: 900;
            background: linear-gradient(135deg, var(--cyber-cyan), var(--cyber-magenta));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .status-indicators {
            position: absolute;
            bottom: 20px;
            right: 20px;
            display: flex;
            gap: 10px;
        }

        .status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--neon-green);
            box-shadow: 0 0 10px var(--neon-green);
            animation: statusPulse 2s infinite;
        }

        @keyframes statusPulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }

        .hero-content {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .glitch-text {
            font-family: 'Orbitron', sans-serif;
            font-size: 64px;
            font-weight: 900;
            color: var(--text-white);
            text-transform: uppercase;
            position: relative;
            margin-bottom: 20px;
            animation: glitch 5s infinite;
        }

        @keyframes glitch {
            0%, 90%, 100% {
                text-shadow: 
                    2px 2px var(--cyber-cyan),
                    -2px -2px var(--cyber-magenta);
            }
            92% {
                text-shadow: 
                    -2px 2px var(--cyber-magenta),
                    2px -2px var(--cyber-cyan);
            }
            94% {
                text-shadow: 
                    4px 0 var(--cyber-cyan),
                    -4px 0 var(--cyber-magenta);
            }
        }

        .subtitle {
            font-size: 24px;
            color: var(--cyber-cyan);
            font-weight: 600;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        .tagline {
            font-size: 18px;
            color: var(--text-gray);
            line-height: 1.8;
            margin-bottom: 30px;
            border-left: 3px solid var(--cyber-magenta);
            padding-left: 20px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 40px;
            animation: slideUp 1s ease-out 0.6s both;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .stat-box {
            background: var(--mid-gray);
            border: 2px solid var(--cyber-cyan);
            padding: 25px;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
        }

        .stat-box::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(0, 255, 255, 0.1), transparent);
            transform: rotate(45deg);
            transition: all 0.5s;
        }

        .stat-box:hover::before {
            left: 100%;
        }

        .stat-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 255, 255, 0.4);
            border-color: var(--cyber-magenta);
        }

        .stat-number {
            font-family: 'Orbitron', sans-serif;
            font-size: 48px;
            font-weight: 900;
            color: var(--cyber-cyan);
            display: block;
            margin-bottom: 10px;
        }

        .stat-label {
            font-size: 14px;
            color: var(--text-gray);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* Contact Panel */
        .contact-panel {
            background: linear-gradient(135deg, var(--dark-gray), var(--mid-gray));
            border: 2px solid var(--cyber-magenta);
            padding: 20px;
            margin-bottom: 40px;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 20px;
            box-shadow: 0 0 20px rgba(255, 0, 255, 0.3);
            animation: slideUp 1s ease-out 0.9s both;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            transition: all 0.3s;
        }

        .contact-item:hover {
            transform: scale(1.1);
            color: var(--cyber-cyan);
        }

        .contact-icon {
            font-size: 24px;
            color: var(--cyber-cyan);
        }

        .contact-item a {
            color: var(--text-white);
            text-decoration: none;
            transition: color 0.3s;
        }

        .contact-item a:hover {
            color: var(--cyber-cyan);
            text-shadow: 0 0 10px var(--cyber-cyan);
        }

        /* Main Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 30px;
            margin-bottom: 40px;
        }

        /* Section Styles */
        .section {
            background: var(--dark-gray);
            border: 2px solid var(--cyber-cyan);
            padding: 30px;
            margin-bottom: 30px;
            position: relative;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.2);
            animation: fadeInSection 0.8s ease-out both;
        }

        @keyframes fadeInSection {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--cyber-cyan), var(--cyber-magenta), var(--cyber-yellow));
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid var(--light-gray);
        }

        .section-icon {
            font-size: 32px;
            color: var(--cyber-cyan);
        }

        .section-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-white);
            text-transform: uppercase;
        }

        /* Experience Entry */
        .experience-entry {
            margin-bottom: 35px;
            padding: 25px;
            background: var(--mid-gray);
            border-left: 4px solid var(--cyber-magenta);
            position: relative;
            transition: all 0.3s;
        }

        .experience-entry:hover {
            transform: translateX(10px);
            border-left-color: var(--cyber-cyan);
            box-shadow: -5px 0 15px rgba(0, 255, 255, 0.3);
        }

        .entry-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
            gap: 20px;
        }

        .entry-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--cyber-cyan);
            margin-bottom: 5px;
        }

        .entry-company {
            font-size: 18px;
            color: var(--cyber-magenta);
            font-weight: 600;
        }

        .entry-date {
            font-family: 'Share Tech Mono', monospace;
            font-size: 14px;
            color: var(--neon-green);
            background: var(--dark-gray);
            padding: 8px 15px;
            border: 1px solid var(--neon-green);
            white-space: nowrap;
        }

        .entry-description {
            color: var(--text-gray);
            margin-bottom: 15px;
            font-size: 16px;
            line-height: 1.7;
        }

        .entry-bullets {
            list-style: none;
            padding: 0;
        }

        .entry-bullets li {
            color: var(--text-gray);
            margin-bottom: 12px;
            padding-left: 30px;
            position: relative;
            font-size: 15px;
            line-height: 1.6;
        }

        .entry-bullets li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: var(--cyber-cyan);
            font-size: 20px;
        }

        /* Skills Grid */
        .skills-container {
            display: grid;
            gap: 20px;
        }

        .skill-category {
            background: var(--mid-gray);
            border: 2px solid var(--cyber-cyan);
            border-radius: 0;
            padding: 20px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .skill-category::after {
            content: '';
            position: absolute;
            top: 0;
            right: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.1));
            transition: right 0.5s;
        }

        .skill-category:hover::after {
            right: 100%;
        }

        .skill-category:hover {
            border-color: var(--cyber-magenta);
            box-shadow: 0 0 20px rgba(255, 0, 255, 0.4);
        }

        .skill-category-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 16px;
            font-weight: 700;
            color: var(--cyber-magenta);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .skill-category-title::before {
            content: '◆';
            color: var(--cyber-cyan);
            font-size: 16px;
        }

        .skill-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .skill-pill {
            background: var(--dark-gray);
            color: var(--cyber-cyan);
            padding: 8px 16px;
            border: 1px solid var(--cyber-cyan);
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            clip-path: polygon(5px 0, 100% 0, calc(100% - 5px) 100%, 0 100%);
        }

        .skill-pill:hover {
            background: var(--cyber-cyan);
            color: var(--deep-black);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 255, 255, 0.5);
        }

        /* Project Card */
        .project-card {
            background: var(--mid-gray);
            border: 2px solid var(--cyber-magenta);
            padding: 25px;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
        }

        .project-card::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, var(--cyber-cyan), var(--cyber-magenta), var(--cyber-yellow));
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .project-card:hover::before {
            opacity: 1;
        }

        .project-card:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 30px rgba(255, 0, 255, 0.4);
        }

        .project-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--cyber-cyan);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .project-description {
            color: var(--text-gray);
            font-size: 15px;
            line-height: 1.7;
            margin-bottom: 15px;
        }

        .project-tech {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .tech-badge {
            background: var(--dark-gray);
            color: var(--neon-green);
            padding: 5px 12px;
            border: 1px solid var(--neon-green);
            font-size: 12px;
            font-weight: 600;
            font-family: 'Share Tech Mono', monospace;
        }

        /* Education & Certifications */
        .edu-item,
        .cert-item {
            background: var(--mid-gray);
            border-left: 4px solid var(--cyber-cyan);
            padding: 20px;
            margin-bottom: 15px;
            transition: all 0.3s;
        }

        .edu-item:hover,
        .cert-item:hover {
            transform: translateX(5px);
            border-left-color: var(--cyber-magenta);
            box-shadow: -5px 0 15px rgba(0, 255, 255, 0.2);
        }

        .edu-degree,
        .cert-name {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-white);
            margin-bottom: 5px;
        }

        .edu-school,
        .cert-issuer {
            font-size: 15px;
            color: var(--cyber-magenta);
            margin-bottom: 5px;
        }

        .edu-date,
        .cert-year {
            font-family: 'Share Tech Mono', monospace;
            font-size: 13px;
            color: var(--neon-green);
            margin-bottom: 10px;
        }

        .edu-description {
            font-size: 14px;
            color: var(--text-gray);
            line-height: 1.6;
        }

        /* Patents Section */
        .patent-badge {
            background: linear-gradient(135deg, var(--mid-gray), var(--dark-gray));
            border: 2px solid var(--cyber-yellow);
            padding: 20px;
            margin-bottom: 15px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
        }

        .patent-badge::before {
            content: '🏆';
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 48px;
            opacity: 0.1;
        }

        .patent-badge:hover {
            border-color: var(--cyber-cyan);
            box-shadow: 0 0 20px rgba(255, 255, 0, 0.4);
            transform: translateY(-3px);
        }

        /* Footer CTA */
        .cta-section {
            background: linear-gradient(135deg, var(--dark-gray), var(--mid-gray));
            border: 3px solid var(--cyber-magenta);
            padding: 50px;
            text-align: center;
            margin-top: 50px;
            position: relative;
            overflow: hidden;
        }

        .cta-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 255, 255, 0.03) 2px,
                rgba(0, 255, 255, 0.03) 4px
            );
            animation: ctaMove 20s linear infinite;
        }

        @keyframes ctaMove {
            0% { transform: translateY(0); }
            100% { transform: translateY(100px); }
        }

        .cta-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 36px;
            font-weight: 900;
            color: var(--cyber-cyan);
            margin-bottom: 20px;
            text-transform: uppercase;
            position: relative;
            z-index: 1;
        }

        .cta-text {
            font-size: 18px;
            color: var(--text-gray);
            margin-bottom: 30px;
            line-height: 1.8;
            position: relative;
            z-index: 1;
        }

        .cta-button {
            display: inline-block;
            background: linear-gradient(45deg, var(--cyber-cyan), var(--cyber-magenta));
            color: var(--deep-black);
            padding: 18px 50px;
            font-size: 18px;
            font-weight: 700;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 2px;
            border: none;
            position: relative;
            overflow: hidden;
            transition: all 0.3s;
            clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
            z-index: 1;
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: var(--cyber-yellow);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.5s, height 0.5s;
        }

        .cta-button:hover::before {
            width: 300px;
            height: 300px;
        }

        .cta-button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px rgba(0, 255, 255, 0.6);
        }

        .cta-button span {
            position: relative;
            z-index: 1;
        }

        /* Responsive Design */
        @media (max-width: 1400px) {
            .content-grid {
                grid-template-columns: 1fr 350px;
            }
        }

        @media (max-width: 1200px) {
            .hero {
                grid-template-columns: 1fr;
                gap: 30px;
            }

            .avatar-frame {
                width: 250px;
                height: 250px;
                margin: 0 auto;
            }

            .content-grid {
                grid-template-columns: 1fr;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .glitch-text {
                font-size: 42px;
            }

            .subtitle {
                font-size: 20px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .contact-panel {
                flex-direction: column;
            }

            .section {
                padding: 20px;
            }

            .entry-header {
                flex-direction: column;
            }

            .cta-section {
                padding: 30px 20px;
            }
        }

        /* Print Styles */
        @media print {
            .cyber-grid,
            .scanlines,
            .particles {
                display: none;
            }

            body {
                background: white;
                color: black;
            }

            .section {
                border-color: #000;
                box-shadow: none;
            }
        }
    </style>
